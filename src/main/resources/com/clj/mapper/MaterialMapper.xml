<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.clj.mapper.MaterialMapper">

    <resultMap id="BaseResultMap" type="com.clj.domain.Material">
            <id property="materialId" column="material_id" />
            <result property="materialName" column="material_name" />
            <result property="typeId" column="type_id" />
            <result property="stock" column="stock" />
            <result property="warningStock" column="warning_stock" />
            <result property="createTime" column="create_time" />
    </resultMap>

    <sql id="Base_Column_List">
        material_id,material_name,type_id,stock,warning_stock,create_time
    </sql>
</mapper>
