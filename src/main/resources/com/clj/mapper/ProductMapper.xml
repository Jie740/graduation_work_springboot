<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.clj.mapper.ProductMapper">

    <resultMap id="BaseResultMap" type="com.clj.domain.Product">
            <id property="productId" column="product_id" />
            <result property="productName" column="product_name" />
            <result property="specification" column="specification" />
            <result property="quantity" column="quantity" />
            <result property="processingId" column="processing_id" />
            <result property="status" column="status" />
            <result property="createTime" column="create_time" />
    </resultMap>

    <sql id="Base_Column_List">
        product_id,product_name,specification,quantity,processing_id,status,
        create_time
    </sql>
</mapper>
