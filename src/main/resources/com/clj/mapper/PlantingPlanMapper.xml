        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.clj.mapper.PlantingPlanMapper">

    <resultMap id="BaseResultMap" type="com.clj.domain.PlantingPlan">
            <id property="planId" column="plan_id" />
